{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "react",
    "jsx-a11y",
    "import",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "settings": {
    "react": {
      "linkComponents": [
        { "name": "Link", "linkAttribute": "to" },
        { "name": "NavLink", "linkAttribute": "to" }
      ]
    }
  },
  "ignorePatterns": [
    "dist",
    "build",
    ".cache",
    "node_modules",
    "app/types/strapi-api.ts"
  ]
}
